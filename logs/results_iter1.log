        summary_df = pd.read_csv(summary_filepath)
        print('=== Simulation Summary (Graceful Exit and e-folds) ===')
        print(summary_df.to_string(index=False))
        print('\n=== Verification of Requirements ===')
        for index, row in summary_df.iterrows():
            Ns = row['N_s']
            Ne = row['N_e_num']
