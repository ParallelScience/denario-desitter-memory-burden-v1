        print("Number of blue-tilted (n_s > 1) combinations: " + str(len(blue_tilted)))
        if len(blue_tilted) > 0:
            print("Note: The model predicts a blue-tilted spectrum (n_s > 1) near the metastable fixed point.")
            print("This is because eta ~ 1/N_e > 0, leading to n_s = 1 - 6*epsilon + 2*eta > 1.")

if __name__ == '__main__':
