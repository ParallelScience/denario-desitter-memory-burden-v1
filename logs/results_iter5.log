                    count += 1
                    N0 = 1.0 / H0**2
                    Q0 = 0.0
                    Ne0 = 0.0
                    def system_tau(tau, y):
                        N, Q, Ne = y
                        if N <= 0:
                            return [0, 0, 0]
                        H = N**(-0.5)
                        dN_dtau = (-H + gamma * Q / N**2) / H0
                        dQ_dtau = (alpha * N_s * H) / H0
                        dNe_dtau = H / H0
                        return [dN_dtau, dQ_dtau, dNe_dtau]
                    def event_bounce(tau, y):
