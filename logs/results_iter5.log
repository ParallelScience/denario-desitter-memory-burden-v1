    for p in params_list:
        gamma, alpha, N_s = p
        print('Integrating for gamma=' + str(gamma) + ', alpha=' + str(alpha) + ', N_s=' + str(N_s) + '...')
        sol = solve_ivp(system, [0, tau_max], [N0, Q0], t_eval=t_eval, args=(gamma, alpha, N_s), events=[event_N_zero], method='Radau', rtol=1e-8, atol=1e-5)
        results[p] = sol
