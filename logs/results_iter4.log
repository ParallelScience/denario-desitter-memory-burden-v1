            print("H = " + ("%.1e" % H) + " M_Pl, N_s = " + str(Ns) + " -> t_qb = " + ("%.3e" % t_qb) + " M_Pl^-1, N_e = " + ("%.3e" % N_e) + " (Ratio N_e/Expected: " + ("%.5f" % ratio) + ")")
