    ax_Q = fig.add_subplot(gs[0, 1])
    ax_H = fig.add_subplot(gs[0, 2])
    ax_Ne = fig.add_subplot(gs[1, 0])
    ax_phase = fig.add_subplot(gs[1, 1:])
    colors = {10: '#1f77b4', 100: '#ff7f0e', 1000: '#2ca02c'}
