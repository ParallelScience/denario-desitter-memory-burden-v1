**Code Explanation:**

The code loads the numerical data generated in Steps 3 and 4 (`selection_data.npz` and `simulation_data.npz`) to synthesize the constraints and observational overlap into a single multi-panel figure. 

The figure consists of three subplots:
1. **(a) Constraints Phase Diagram**: Plots the theoretical bounds on the number of species $N_s$ as a function of the Hubble scale $H/M_{Pl}$. It shows the absolute species cutoff ($N_s \le 1/H^2$) and the stricter e-fold constraint required to achieve at least 60 e-folds of inflation ($N_s \le 1/(60 H^2)$). The forbidden regions are shaded.
2. **(b) Stability Corridor Heatmap**: Displays the actual number of e-folds $N_e$ achieved before quantum breaking, obtained from the numerical integration in Step 4. The theoretical constraint lines are overlaid to demonstrate the agreement between the analytical bounds and the numerical simulation.
3. **(c) Dynamical Selection**: Plots the curves for the dynamical selection mechanism $N_s \cdot F(1/H) = 1/H^2$ for various functional forms of $F$, showing how a specific inflationary scale $H$ can be dynamically selected given a number of species $N_s$.

All three subplots include a vertical shaded green strip representing the CMB-motivated observational band for the inflationary Hubble scale ($10^{-5} \le H/M_{Pl} \le 10^{-4}$). The script also prints quantitative details regarding the maximum allowed species within this band and the corresponding $N_s$ ranges for the dynamical selection models, providing the necessary numerical context for the final report.

**Python Code:**

```python
import os
import time
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.colors as mcolors

def load_and_plot_synthesis(data_dir):
    """
    Loads data from previous steps and generates a multi-panel synthesis figure.
    
    The figure contains three subplots:
    (a) Phase diagram showing the species cutoff and e-fold constraint.
    (b) Heatmap of the stability corridor showing the number of e-folds achieved.
    (c) Dynamical selection curves for various memory load functionals.
    
    All plots include a shaded vertical strip representing the CMB-motivated
    observational band for the Hubble scale (1e-5 to 1e-4).
    
    Args:
        data_dir (str): Directory where data files are stored and plots will be saved.
    """
    plt.rcParams['text.usetex'] = False
    
    selection_data = np.load(os.path.join(data_dir, "selection_data.npz"))
    H_sel = selection_data['H_vals']
    Ns_const = selection_data['Ns_const']
    Ns_log = selection_data['Ns_log']
    Ns_pow_05 = selection_data['Ns_pow_05']
    Ns_pow_1 = selection_data['Ns_pow_1']
    Ns_pow_2 = selection_data['Ns_pow_2']
    
    sim_data = np.load(os.path.join(data_dir, "simulation_data.npz"))
    N_s_sim = sim_data['N_s_vals']
    H_sim = sim_data['H_vals']
    N_e_matrix = sim_data['N_e_matrix']
    
    fig, axes = plt.subplots(1, 3, figsize=(18, 6))
    
    H_obs_min = 1e-5
    H_obs_max = 1e-4
    
    ax1 = axes[0]
    H_grid = np.logspace(-6, -1, 500)
    Ns_cutoff = 1.0 / H_grid**2
    Ns_efold = 1.0 / (60.0 * H_grid**2)
    
    ax1.plot(H_grid, Ns_cutoff, 'r-', lw=2, label='Species Cutoff (N_s = 1/H^2)')
    ax1.plot(H_grid, Ns_efold, 'b--', lw=2, label='e-fold Constraint (N_e=60)')
    
    ax1.fill_between(H_grid, Ns_cutoff, 1e15, color='red', alpha=0.2, label='Forbidden (Cutoff)')
    ax1.fill_between(H_grid, Ns_efold, Ns_cutoff, color='blue', alpha=0.1, label='Forbidden (N_e < 60)')
    
    ax1.axvspan(H_obs_min, H_obs_max, color='green', alpha=0.2, label='CMB Band')
    
    ax1.set_xscale('log')
    ax1.set_yscale('log')
    ax1.set_xlim(1e-6, 1e-1)
    ax1.set_ylim(1e0, 1e13)
    ax1.set_xlabel('Hubble Scale H / M_Pl', fontsize=12)
    ax1.set_ylabel('Number of Species N_s', fontsize=12)
    ax1.set_title('(a) Constraints Phase Diagram', fontsize=14)
    ax1.grid(True, which="both", ls="--", alpha=0.5)
    ax1.legend(fontsize=9, loc='upper right')
    
    ax2 = axes[1]
    H_mesh, Ns_mesh = np.meshgrid(H_sim, N_s_sim)
    N_e_plot = np.clip(N_e_matrix, 1e-2, None)
    c = ax2.pcolormesh(H_mesh, Ns_mesh, N_e_plot, shading='auto', cmap='viridis', norm=mcolors.LogNorm(vmin=1, vmax=1e5))
    fig.colorbar(c, ax=ax2, label='Number of e-folds N_e')
    
    ax2.plot(H_grid, Ns_cutoff, 'r-', lw=1.5)
    ax2.plot(H_grid, Ns_efold, 'b--', lw=1.5)
    
    ax2.axvspan(H_obs_min, H_obs_max, color='green', alpha=0.2)
    
    ax2.set_xscale('log')
    ax2.set_yscale('log')
    ax2.set_xlim(1e-5, 1e-2)
    ax2.set_ylim(1e0, 1e8)
    ax2.set_xlabel('Hubble Scale H / M_Pl', fontsize=12)
    ax2.set_ylabel('Number of Species N_s', fontsize=12)
    ax2.set_title('(b) Stability Corridor (N_e Heatmap)', fontsize=14)
    ax2.grid(True, which="both", ls="--", alpha=0.5)
    
    ax3 = axes[2]
    ax3.plot(H_sel, Ns_const, label='F = 1', lw=2)
    ax3.plot(H_sel, Ns_log, label='F = ln(1/H)', lw=2)
    ax3.plot(H_sel, Ns_pow_05, label='F = (1/H)^0.5', lw=2)
    ax3.plot(H_sel, Ns_pow_1, label='F = 1/H', lw=2)
    ax3.plot(H_sel, Ns_pow_2, label='F = (1/H)^2', lw=2, linestyle='--')
    
    ax3.axvspan(H_obs_min, H_obs_max, color='green', alpha=0.2, label='CMB Band')
    
    ax3.set_xscale('log')
    ax3.set_yscale('log')
    ax3.set_xlim(1e-6, 1e-1)
    ax3.set_ylim(1e0, 1e13)
    ax3.set_xlabel('Hubble Scale H / M_Pl', fontsize=12)
    ax3.set_ylabel('Number of Species N_s', fontsize=12)
    ax3.set_title('(c) Dynamical Selection', fontsize=14)
    ax3.grid(True, which="both", ls="--", alpha=0.5)
    ax3.legend(fontsize=9, loc='upper right')
    
    plt.tight_layout()
    
    timestamp = int(time.time())
    plot_filename = os.path.join(data_dir, "synthesis_constraints_5_" + str(timestamp) + ".png")
    plt.savefig(plot_filename, dpi=300)
    
    print("Synthesis plot saved to " + plot_filename)
    print("\n--- Synthesis of Constraints and Observational Overlap ---")
    print("Loaded selection data from selection_data.npz")
    print("Loaded simulation data from simulation_data.npz")
    print("Generated multi-panel figure with 3 subplots:")
    print("  (a) Phase diagram showing Species Cutoff and e-fold Constraint (N_e = 60).")
    print("  (b) Stability Corridor Heatmap showing achieved e-folds N_e.")
    print("  (c) Dynamical Selection curves for various memory load functionals F(1/H).")
    print("Marked CMB-motivated observational band (H/M_Pl ~ 1e-5 to 1e-4) on all plots.")
    
    print("\n--- Quantitative Analysis of Observational Overlap ---")
    
    H_1 = 1e-5
    Ns_max_1 = 1.0 / (60.0 * H_1**2)
    print("At H/M_Pl = 1e-5 (lower CMB bound):")
    print("  Maximum allowed species for N_e >= 60: N_s <= " + str(Ns_max_1))
    
    H_2 = 1e-4
    Ns_max_2 = 1.0 / (60.0 * H_2**2)
    print("At H/M_Pl = 1e-4 (upper CMB bound):")
    print("  Maximum allowed species for N_e >= 60: N_s <= " + str(Ns_max_2))
    
    idx_cmb = (H_sel >= 1e-5) & (H_sel <= 1e-4)
    print("\nDynamical Selection N_s ranges within CMB band (1e-5 <= H/M_Pl <= 1e-4):")
    print("  Constant F=1: N_s from " + str(np.min(Ns_const[idx_cmb])) + " to " + str(np.max(Ns_const[idx_cmb])))
    print("  Logarithmic F=ln(1/H): N_s from " + str(np.min(Ns_log[idx_cmb])) + " to " + str(np.max(Ns_log[idx_cmb])))
    print("  Power-law delta=0.5: N_s from " + str(np.min(Ns_pow_05[idx_cmb])) + " to " + str(np.max(Ns_pow_05[idx_cmb])))
    print("  Power-law delta=1.0: N_s from " + str(np.min(Ns_pow_1[idx_cmb])) + " to " + str(np.max(Ns_pow_1[idx_cmb])))
    print("  Power-law delta=2.0: N_s = 1.0 (constant)")

def main():
    """
    Main execution function.
    """
    data_dir = "data"
    load_and_plot_synthesis(data_dir)

if __name__ == '__main__':
    main()
```

